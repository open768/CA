{
    "compilerOptions": {
        "target": "ES6",
        "checkJs": true,
        "allowJs": true,
        "noEmit": true,
        "strict": false,
        "typeRoots": [
            "./node_modules/@types",
            "${env:APPDATA}/npm/node_modules/@types",
            "../jsinc/extra"
        ]
    },
    "include": [
        "**/*.js",
        "globals.d.ts",
        "../jsinc/ck-inc/*.js"
    ],
    "exclude": [
        "node_modules",
        "**/bower_components",
        "**/dist",
        "**/build",
        "**/test"
    ]
}